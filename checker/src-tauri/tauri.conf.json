{
  "$schema": "../node_modules/@tauri-apps/cli/schema.json",
  "productName": "CS2Checker",
  "version": "2.0.0",
  "identifier": "com.cs2checker.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "CS2Checker",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "decorations": false,
        "transparent": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https://*.steamstatic.com; connect-src 'self' https://api.steampowered.com https://cs2checker.ru https://api.telegram.org"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png",
      "icons/icon.ico"
    ]
  }
}
